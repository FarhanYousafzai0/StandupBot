# Copy to `.env.local` (not committed).
#
# In local dev, point at Next (3000) so the browser only talks to one origin; Next
# proxies /api to Express (default 5000). Optional: API_PROXY_TARGET in next.config
# defaults to http://127.0.0.1:5000
#
# Or leave empty for strict same-origin relative URLs.
NEXT_PUBLIC_API_URL=http://localhost:3000
#
# For production or to call the API port directly (no proxy), e.g.:
# NEXT_PUBLIC_API_URL=https://your-api.example.com
