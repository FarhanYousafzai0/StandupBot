# Copy to `apps/api/.env` and adjust (never commit .env)
NODE_ENV=development
PORT=5000
# Same cluster for both: SRV here; optional "standard" (non-srv) from Atlas for this project if SRV/DNS fails
MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/standupbot?retryWrites=true&w=majority&appName=Cluster0
MONGODB_URI_DIRECT=
JWT_SECRET=change_me_to_a_long_random_string

# Next.js app origin (CORS) — no trailing path
WEB_ORIGIN=http://localhost:3000

# OpenAI (ChatGPT) — required for POST /api/standup/generate
OPENAI_API_KEY=
# Examples: gpt-4o-mini, gpt-4o, gpt-4.1, gpt-4.1-mini
OPENAI_MODEL=gpt-4o-mini

# Public base URL of this API (GitHub OAuth callback). Dev: http://localhost:5000
API_PUBLIC_URL=http://localhost:5000
# GitHub OAuth (Integrations) — create an OAuth app; callback: {API_PUBLIC_URL}/api/integrations/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Slack OAuth (bot) — create at api.slack.com; Redirect URL: {API_PUBLIC_URL}/api/integrations/slack/callback
# Bot scopes: chat:write, im:write, users:read
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
