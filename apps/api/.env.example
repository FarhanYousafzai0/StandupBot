# Copy to `apps/api/.env` and fill in values. Never commit `.env` (real secrets).
NODE_ENV=development
PORT=5000
# Same cluster: SRV here; optional "standard" (non-srv) from Atlas if SRV/DNS (`querySrv`) fails
MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/standupbot?retryWrites=true&w=majority&appName=Cluster0
MONGODB_URI_DIRECT=
JWT_SECRET=change_me_to_a_long_random_string

# Next.js app origin (CORS) — no trailing path
WEB_ORIGIN=http://localhost:3000

# OpenAI (ChatGPT) — required for POST /api/standup/generate
OPENAI_API_KEY=
# Examples: gpt-4o-mini, gpt-4o, gpt-4.1, gpt-4.1-mini
OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# API_PUBLIC_URL — public base of THIS Express API (no trailing slash).
#   Local dev: http://localhost:5000
#   Production: https://api.yourdomain.com (must match your deployed API URL)
# This value MUST match the OAuth "callback / redirect" hosts you register
# in GitHub and Slack (see below), character-for-character.
# ---------------------------------------------------------------------------
API_PUBLIC_URL=http://localhost:5000

# ---------------------------------------------------------------------------
# GitHub OAuth (Integrations > Connect GitHub)
#
# 1) GitHub: Settings → Developer settings → OAuth Apps → New OAuth App
# 2) Application name: e.g. Standup Bot (local)
# 3) Homepage URL:  http://localhost:3000  (or your app URL in prod)
# 4) Authorization callback URL (exact, one line):
#      {API_PUBLIC_URL}/api/integrations/github/callback
#    e.g. http://localhost:5000/api/integrations/github/callback
# 5) Create → copy Client ID → generate Client secret → paste below
# ---------------------------------------------------------------------------


# ---------------------------------------------------------------------------
# Slack OAuth (Integrations > Connect Slack)
#
# 1) https://api.slack.com/apps → Create New App (from manifest or scratch)
# 2) OAuth & Permissions → add Redirect URL (exact):
#      {API_PUBLIC_URL}/api/integrations/slack/callback
#    e.g. http://localhost:5000/api/integrations/slack/callback
# 3) Bot token scopes (OAuth scope): as required by the app, at minimum the
#    app documents:  chat:write, im:write, users:read
# 4) Install to workspace (dev) for testing
# 5) Basic Information → copy Client ID & Client Secret → paste below
# ---------------------------------------------------------------------------

